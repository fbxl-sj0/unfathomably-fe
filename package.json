{
  "name": "unfathomably-fe",
  "displayName": "Unfathomably FE",
  "version": "3.2.0",
  "type": "module",
  "description": "Unfathomably frontend for the Fediverse.",
  "homepage": "https://github.com/fbxl-sj0/unfathomably-fe",
  "repository": {
    "type": "git",
    "url": "https://github.com/fbxl-sj0/unfathomably-fe"
  },
  "keywords": [
    "unfathomably",
    "fediverse",
    "pleroma"
  ],
  "bugs": {
    "url": "https://github.com/fbxl-sj0/unfathomably-fe/issues"
  },
  "scripts": {
    "start": "vite serve",
    "dev": "yarn && yarn start",
    "build": "vite build --emptyOutDir",
    "check": "tsc --noEmit",
    "preview": "vite preview",
    "i18n": "formatjs extract \"src/**/*.{ts,tsx}\" --ignore \"src/**/*.d.ts\" --out-file build/messages.json && formatjs compile build/messages.json --out-file src/locales/en.json",
    "i18n:check": "node scripts/check-i18n.cjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:migration": "vitest run src/components/scrollable-list.behavior.test.tsx src/components/status-list.behavior.test.tsx",
    "test:federation": "vitest run src/features/federation/platform.test.ts src/features/federation/native-source-item-card.test.tsx src/features/sources/source-items-preview.test.tsx src/schemas/source-item.test.ts src/schemas/group.test.ts",
    "strict": "npm run lint && npm run i18n:check && tsc --noEmit && vitest run && vite build --emptyOutDir",
    "baseline": "npm run strict",
    "lint": "npm run lint:js && npm run lint:styles",
    "lint:js": "eslint --ext .js,.jsx,.cjs,.mjs,.ts,.tsx . --cache --max-warnings 0",
    "lint:styles": "stylelint \"src/**/*.{css,scss}\" \"tailwind/**/*.{css,scss}\" --allow-empty-input --max-warnings 0",
    "ci": "concurrently --kill-others-on-fail \"npm run lint\" \"npm run i18n:check\" \"npm run check\" \"npm run build\"",
    "prepare": "husky"
  },
  "license": "AGPL-3.0-or-later",
  "packageManager": "yarn@4.17.0",
  "engines": {
    "node": ">=26.3.1"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "dependencies": {
    "@dr.pogodin/react-helmet": "^3.2.2",
